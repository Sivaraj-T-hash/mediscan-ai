# ─── HealthGuard AI v4.0 — Environment Configuration ────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── AI Provider ───────────────────────────────────────────────────────────────
# Primary provider is OpenAI. Change to "claude", "gemini", or "none" if needed.
AI_PROVIDER=openai

# ── OpenAI (primary) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# ── Claude (optional fallback provider) ───────────────────────────────────────
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Gemini (optional fallback provider) ───────────────────────────────────────
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_MODEL=gemini-1.5-flash

# ── AI Request Settings ────────────────────────────────────────────────────────
AI_TIMEOUT_MS=10000
AI_MAX_TOKENS=600

# ── Smart Triage Fallback ──────────────────────────────────────────────────────
# Set to "false" to disable automatic fallback (errors will propagate instead)
FALLBACK_ON_AI_ERROR=true
